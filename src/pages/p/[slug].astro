---
import { getCollection, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import PreorderButton from '~/components/PreorderButton.astro';
import ValidationBar from '~/components/ValidationBar.astro';
import GoalExplainer from '~/components/GoalExplainer.astro';
import ShareStrip from '~/components/ShareStrip.astro';
import SampleDownload from '~/components/SampleDownload.astro';
import FAQ from '~/components/FAQ.astro';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((product) => ({
    params: { slug: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const { Content } = await render(product);
const data = product.data;
const productUrl = new URL(`/p/${product.id}`, Astro.site).toString();

const primarySubreddit = data.organicChannels
  .find((c) => c.startsWith('r/'))
  ?.replace(/^r\//, '');
---

<BaseLayout
  title={`${data.title} — pre-order on mannu.in`}
  description={data.tagline}
  ogImage={data.ogImage}
  canonical={productUrl}
>
  <article class="grid gap-10 lg:grid-cols-[1.6fr_1fr]">
    <div>
      <div class="mb-3 text-xs uppercase tracking-wider text-[var(--color-muted)]">
        For {data.buyer}
      </div>
      <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">{data.title}</h1>
      <p class="mt-3 text-xl text-[var(--color-muted)]">{data.tagline}</p>

      <div class="mt-8 flex flex-wrap items-center gap-4">
        <PreorderButton href={data.stripePaymentLinkUrl} priceUsd={data.priceUsd} />
        <span class="text-sm text-[var(--color-muted)]">
          Full price today. Full refund if the goal misses.
        </span>
      </div>

      <div class="mt-10">
        <h2 class="mb-3 text-lg font-semibold">What you get</h2>
        <ul class="space-y-2">
          {data.bullets.map((b) => (
            <li class="flex gap-3 text-sm">
              <span class="mt-0.5 text-[var(--color-accent)]">✓</span>
              <span>{b}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="mt-10 space-y-4 text-base leading-relaxed text-[var(--color-fg)] [&_h2]:text-xl [&_h2]:font-semibold [&_h2]:mt-8 [&_h2]:mb-2 [&_p]:text-[var(--color-muted)] [&_strong]:text-white">
        <Content />
      </div>

      <div class="mt-10">
        <FAQ items={data.faq} />
      </div>
    </div>

    <aside class="space-y-6 lg:sticky lg:top-8 lg:self-start">
      <ValidationBar
        preordersSoFar={data.preordersSoFar}
        preorderGoal={data.preorderGoal}
        deadline={data.deadline}
        status={data.status}
      />
      <GoalExplainer goal={data.preorderGoal} deadline={data.deadline} />
      <SampleDownload samplePath={data.samplePath} title={data.title} />
      <ShareStrip
        productUrl={productUrl}
        title={data.title}
        tagline={data.tagline}
        subreddit={primarySubreddit}
      />
    </aside>
  </article>
</BaseLayout>

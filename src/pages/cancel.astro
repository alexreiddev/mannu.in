---
import BaseLayout from '~/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Pre-order cancelled — mannu.in"
  description="No charge was made. You can pre-order again any time before the deadline."
>
  <section class="mx-auto max-w-2xl py-12 text-center">
    <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">No charge was made.</h1>
    <p class="mt-4 text-lg text-[var(--color-muted)]">
      You left Stripe without completing. Come back any time before the deadline if you change your mind.
    </p>
    <a
      href="/"
      class="mt-8 inline-block rounded-xl border border-[var(--color-border)] bg-white/[0.04] px-5 py-3 text-sm font-medium hover:bg-white/[0.08]"
    >
      Back to the storefront
    </a>
  </section>
</BaseLayout>
